{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "laravel-boost": {
      "type": "local",
      "enabled": true,
      "command": [
        "php",
        "artisan",
        "boost:mcp"
      ]
    },
    "figma-bridge": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@gethopp/figma-mcp-bridge"
      ]
    }
  }
}